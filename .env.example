# ============================================================
# 🚀 快速开始（即填即用）
# ------------------------------------------------------------
# ① 零凭证体验：什么都不用填，直接 `./run.sh`，用 fake 引擎跑通整条链路。
# ② 接真实语音：只需填下面【发声链路】的 VOLC_APP_ID + VOLC_ACCESS_TOKEN，
#    然后 `./run.sh --real`。其余项保持默认即可。
# ③ 记忆/信号增强（选填）：填 ARK_API_KEY 可让记忆蒸馏/信号摘要更自然；
#    留空则自动降级为规则提炼，不影响通话。
# ============================================================

# ============================================================
# 发声链路（接真实语音时必填）：豆包端到端实时语音 Seeduplex
# 控制台：https://console.volcengine.com/speech/service/10017
# 注意：这是「语音」鉴权体系，与下方方舟 ARK_API_KEY 完全独立、不可混用。
# 没有这两项，agent 无法出声（L0/L1/L2 无法验收）。
# ============================================================
VOLC_APP_ID=你的AppID
VOLC_ACCESS_TOKEN=你的AccessToken
# 端到端模型版本：O（通用，支持人设/联网）或 SC（角色扮演，支持克隆音色）
VOLC_MODEL=O
# 发音人音色，老年陪伴推荐温和女声 vv（这是「默认音色」，老人未启用克隆角色时用它）
VOLC_SPEAKER=zh_female_vv_jupiter_bigtts

# ------------------------------------------------------------
# 声音克隆（声音复刻）：让小陪用「老人喜爱对象」的嗓音说话
# 复用上面的 VOLC_APP_ID + VOLC_ACCESS_TOKEN（同一套语音鉴权，无需额外凭证）。
# 使用前提：先在火山控制台购买「声音复刻」资源包，拿到音色代号 speaker_id（S_开头），
# 然后在老人端「换个声音」页填入代号并上传录音即可训练；训练就绪后通话自动用克隆音色。
# 控制台：https://console.volcengine.com/speech/service/10007
# 未配置 VOLC 凭证时，声音克隆进入 mock 模式（界面可走通，但不产生真实音色）。
# ------------------------------------------------------------

# 发声引擎，固定 seeduplex
VOICE_ENGINE=seeduplex

# ============================================================
# 文本链路（选填）：火山方舟 LLM —— 仅用于 L3 记忆蒸馏 / L4 子女端信号
# 控制台：https://console.volcengine.com/ark
# 留空则记忆/信号降级为规则提炼，不影响语音通话。
# ============================================================
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_TEXT_MODEL=doubao-seed-1-6-flash
# 文本模型单价（元/百万 token），仅用于子女端成本看板折算展示，不影响实际计费。
# 默认按 doubao-seed-1-6-flash 公开价估算；请以方舟控制台实际账单为准。
ARK_PRICE_PER_MTOKEN=0.8

# 服务监听
HOST=0.0.0.0
PORT=8000

# ============================================================
# 前后端分离部署（选填）：默认后端同源托管前端，无需配置。
# 若前端单独部署在别的域名，在此填放行的源（逗号分隔），并在前端
# web/elder/config.js 与 web/parent/config.js 里填 API_BASE 指向后端。
# 例：CORS_ALLOW_ORIGINS=https://elder.example.com,https://parent.example.com
# ============================================================
CORS_ALLOW_ORIGINS=
